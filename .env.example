# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL (Prisma) — Supabase: Transaction Pooler (6543) kullan
# Dashboard: Project Settings → Database → Connection string → Transaction pooler
# Region: Supabase Dashboard → Database → Connection string → Session pooler (host satırından al)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Direct connection (migrate için, opsiyonel)
# DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase (DB + Storage)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Storage — S3-compatible API (Vercel / cloud-native upload)
# Dashboard: Storage → S3 Connection
AWS_S3_ENDPOINT=https://[PROJECT_REF].storage.supabase.co/storage/v1/s3
AWS_S3_BUCKET=c4e-uploads
AWS_REGION=eu-central-1
# Supabase: anon → access key, service_role → secret (veya S3 Connection key'lerini doğrudan yaz)
AWS_ACCESS_KEY_ID=your-anon-key
AWS_SECRET_ACCESS_KEY=your-service-role-key
# Public URL override (opsiyonel — yoksa otomatik supabase.co/object/public/... üretilir)
# AWS_S3_PUBLIC_BASE_URL=https://[PROJECT_REF].supabase.co/storage/v1/object/public/c4e-uploads

# Redis
REDIS_URL=redis://localhost:6379

# Auth / JWT
JWT_ACCESS_SECRET=replace-with-strong-access-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret-min-32-chars
AUTH_SECRET=replace-with-strong-auth-secret
AUTH_ISSUER=c4e
AUTH_AUDIENCE=c4e-users

# WebSocket / Realtime
WS_HOST=0.0.0.0
WS_PORT=3001
WS_PATH=/ws

# Federation / Main Server
MAIN_SERVER_BADGE_API_URL=https://mainserver.c4e.com/api
