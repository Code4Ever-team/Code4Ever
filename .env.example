# App
# NODE_ENV buraya yazmayın — next dev (development) / next build+start (production) kendi ayarlar
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production site URL (password reset links, absolute URLs). Vercel: set in project env.
NEXT_PUBLIC_SITE_URL=
# Optional: restrict hidden /p4nel panel to this user id (defaults to platform founder)
PLATFORM_PANEL_ADMIN_ID=
# PostgreSQL (Prisma) — Supabase: Transaction Pooler (6543) kullan
# Dashboard: Project Settings → Database → Connection string → Transaction pooler
# Region: Supabase Dashboard → Database → Connection string → Session pooler (host satırından al)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Direct connection (migrate için, opsiyonel)
# DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase (PostgreSQL only)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co

# Vercel Blob (chat + feed medya)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Redis
REDIS_URL=redis://localhost:6379

# Auth / JWT
JWT_ACCESS_SECRET=replace-with-strong-access-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret-min-32-chars
AUTH_SECRET=replace-with-strong-auth-secret
AUTH_ISSUER=c4e
AUTH_AUDIENCE=c4e-users

# WebSocket / Realtime
WS_HOST=0.0.0.0
WS_PORT=3002
WS_PATH=/ws

# Collab WebSocket (defaults to ws://localhost:3002/collab)
NEXT_PUBLIC_COLLAB_WS_URL=
NEXT_PUBLIC_COLLAB_WS_PORT=3002

# Federation / Main Server
MAIN_SERVER_BADGE_API_URL=https://mainserver.c4e.com/api

# SMTP (şifre sıfırlama e-postası)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Code4Ever <noreply@yourdomain.com>"
